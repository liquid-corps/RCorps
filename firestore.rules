rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Nadie lee/escribe directo desde el navegador: todo pasa por
    // las Cloud Functions (que usan el Admin SDK y se saltan estas reglas).
    // Esto evita que alguien vea claves, códigos de recuperación o
    // manipule "usernames"/"users" editando el JS del navegador.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
